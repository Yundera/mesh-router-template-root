# Install script test configuration
# Copy this file to .env and fill in your values

# Provider connection string: <backend_url>,<userid>,<signature>
PROVIDER=https://inojob.com,your_user_id,your_signature

# Your domain
DOMAIN=yourname.inojob.com

# Password (optional, auto-generated if omitted)
PASSWORD=changeme

# Public IP (optional, auto-detected if omitted)
PUBLIC_IP=
